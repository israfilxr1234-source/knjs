rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isVerifiedEmail() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Role checks
    function isAdmin() { 
      return isSignedIn() && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'admin';
    }

    // Validation helpers
    function isValidMember(data) {
      return data.keys().hasAll(['userId', 'name', 'rank', 'phone', 'role']) &&
             data.keys().size() <= 8 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.rank is string && data.rank.size() > 0 &&
             data.phone is string && data.phone.size() >= 10 &&
             data.role in ['admin', 'member'];
    }

    function isValidNotice(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'createdAt', 'type']) &&
             data.keys().size() == 6 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time &&
             data.type in ['urgent', 'info', 'meeting'];
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'description', 'dateTime', 'location', 'organizerId']) &&
             data.keys().size() == 5 &&
             data.title is string && data.title.size() <= 200 &&
             data.dateTime is string && // Simplified for now, production should use timestamps
             data.location is string && data.location.size() <= 300;
    }

    function isValidFund(data) {
      return data.keys().hasAll(['amount', 'type', 'description', 'date']) &&
             data.keys().size() >= 4 &&
             data.amount is number && data.amount > 0 &&
             data.type in ['donation', 'expense'] &&
             data.date == request.time;
    }

    // 1. Members
    match /members/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidMember(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidMember(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'rank', 'phone', 'photoURL']);
      allow delete: if isAdmin();
    }

    // 2. Notices
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(noticeId) && isValidNotice(incoming());
      allow update: if isAdmin() && isValidNotice(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'type']);
      allow delete: if isAdmin();
    }

    // 3. Events
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isAdmin() && isValidEvent(incoming());
      allow delete: if isAdmin();
    }

    // 4. Funds
    match /funds/{fundId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(fundId) && isValidFund(incoming());
      allow delete: if isAdmin();
    }
  }
}
